<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LaserGRBL.Avalonia.MainWindow"
        Title="{Binding Title}"
        MinWidth="980"
        MinHeight="620"
        Width="1180"
        Height="760"
        x:CompileBindings="False"
        Background="{Binding Theme.WindowBackground}">
  <Grid RowDefinitions="48,*,120" ColumnDefinitions="300,*">
    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{Binding Theme.HeaderBackground}" BorderBrush="{Binding Theme.Border}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
        <TextBlock Text="LaserGRBL" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
        <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="18,0,0,0" Foreground="{Binding Theme.MutedText}" />
        <TextBlock Grid.Column="2" Text="{Binding FirmwareText}" VerticalAlignment="Center" Foreground="{Binding Theme.MutedText}" />
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Background="{Binding Theme.PanelBackground}" BorderBrush="{Binding Theme.Border}" BorderThickness="0,0,1,0">
      <StackPanel Margin="14" Spacing="12">
        <TextBlock Text="Connection" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
        <Border MinHeight="96" Padding="12" BorderBrush="{Binding Theme.Border}" BorderThickness="1" CornerRadius="6" Background="{Binding Theme.SurfaceBackground}">
          <StackPanel Spacing="8">
            <TextBlock Text="{Binding ConnectionSummary}" Foreground="{Binding Theme.Text}" />
            <TextBlock Text="{Binding DeviceAccessSummary}" TextWrapping="Wrap" Foreground="{Binding Theme.MutedText}" />
          </StackPanel>
        </Border>

        <TextBlock Text="Controls" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
        <Grid ColumnDefinitions="*,*" RowDefinitions="40,40,40" ColumnSpacing="8" RowSpacing="8">
          <Button Content="Connect" IsEnabled="False" />
          <Button Grid.Column="1" Content="Disconnect" IsEnabled="False" />
          <Button Grid.Row="1" Content="Run" IsEnabled="False" />
          <Button Grid.Row="1" Grid.Column="1" Content="Hold" IsEnabled="False" />
          <Button Grid.Row="2" Content="Reset" IsEnabled="False" />
          <Button Grid.Row="2" Grid.Column="1" Content="Unlock" IsEnabled="False" />
        </Grid>

        <TextBlock Text="Diagnostics" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
        <ItemsControl ItemsSource="{Binding Diagnostics}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="{Binding $parent[Window].DataContext.Theme.Warning}" Margin="0,0,0,6" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="*,170">
      <Border Margin="14" BorderBrush="{Binding Theme.Border}" BorderThickness="1" CornerRadius="6" Background="{Binding Theme.PreviewBackground}">
        <Grid>
          <TextBlock Text="Preview renderer placeholder" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Theme.PreviewPath}" FontSize="18" />
          <TextBlock Text="{Binding PreviewSummary}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,54,0,0" Foreground="{Binding Theme.MutedText}" />
        </Grid>
      </Border>

      <Border Grid.Row="1" Margin="14,0,14,14" BorderBrush="{Binding Theme.Border}" BorderThickness="1" CornerRadius="6" Background="{Binding Theme.LogBackground}">
        <Grid RowDefinitions="32,*">
          <TextBlock Text="Log" Margin="12,8,12,0" FontWeight="SemiBold" Foreground="{Binding Theme.LogText}" />
          <ItemsControl Grid.Row="1" Margin="12,4,12,12" ItemsSource="{Binding LogLines}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}" Foreground="{Binding $parent[Window].DataContext.Theme.LogText}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{Binding Theme.PanelBackground}" BorderBrush="{Binding Theme.Border}" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,*,*" Margin="16,12" ColumnSpacing="14">
        <StackPanel>
          <TextBlock Text="Paths" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
          <TextBlock Text="{Binding PathsSummary}" TextWrapping="Wrap" Foreground="{Binding Theme.MutedText}" />
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="Settings" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
          <TextBlock Text="{Binding SettingsSummary}" TextWrapping="Wrap" Foreground="{Binding Theme.MutedText}" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Color scheme" FontWeight="SemiBold" Foreground="{Binding Theme.Text}" />
          <TextBlock Text="{Binding Theme.Name}" Foreground="{Binding Theme.Link}" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
